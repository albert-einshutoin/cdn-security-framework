{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CDN Security Framework Policy",
  "description": "Schema for policy/base.yml and policy/profiles/*.yml (v1)",
  "type": "object",
  "required": ["version", "request", "response_headers"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "project": { "type": "string" },
    "defaults": {
      "type": "object",
      "properties": {
        "mode": { "enum": ["enforce", "monitor"] },
        "response": { "type": "object", "properties": { "add_security_headers": { "type": "boolean" } } }
      }
    },
    "request": {
      "type": "object",
      "required": ["allow_methods"],
      "properties": {
        "allow_methods": { "type": "array", "items": { "type": "string" } },
        "allowed_hosts": {
          "description": "Optional Host header allowlist. When set, requests whose Host does not match any entry are rejected at the edge. Entries support exact match (api.example.com) and wildcard prefix (*.example.com).",
          "type": "array",
          "items": { "type": "string" }
        },
        "trust_forwarded_for": {
          "description": "If false (default), any client-supplied X-Forwarded-For header is stripped before the request reaches origin auth / logging. Enable only when the edge sits behind a trusted upstream proxy that you intentionally want to honor.",
          "type": "boolean"
        },
        "limits": {
          "type": "object",
          "properties": {
            "max_query_length": {
              "description": "Maximum querystring length in bytes. Requests exceeding this are rejected at the edge.",
              "type": "integer",
              "minimum": 1,
              "maximum": 65536
            },
            "max_query_params": {
              "description": "Maximum number of querystring keys. Protects against HTTP parameter pollution and cache poisoning.",
              "type": "integer",
              "minimum": 1,
              "maximum": 1024
            },
            "max_uri_length": {
              "description": "Maximum request URI (path + query) length in bytes.",
              "type": "integer",
              "minimum": 1,
              "maximum": 8192
            },
            "max_header_size": {
              "description": "Maximum individual request header value size in bytes.",
              "type": "integer",
              "minimum": 1,
              "maximum": 65536
            }
          }
        },
        "block": {
          "type": "object",
          "properties": {
            "path_patterns": {
              "oneOf": [
                {
                  "description": "Legacy shape: list of literal substrings. Regex-style entries are rejected at build time; use the object form instead.",
                  "type": "array",
                  "items": { "type": "string" }
                },
                {
                  "description": "Typed shape: literal substrings under contains, RegExp sources under regex (compiled at build time).",
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "contains": { "type": "array", "items": { "type": "string" } },
                    "regex": { "type": "array", "items": { "type": "string" } }
                  }
                }
              ]
            },
            "ua_contains": { "type": "array", "items": { "type": "string" } },
            "header_missing": { "type": "array", "items": { "type": "string" } }
          }
        },
        "normalize": {
          "type": "object",
          "properties": {
            "drop_query_keys": { "type": "array", "items": { "type": "string" } },
            "path": {
              "type": "object",
              "properties": {
                "collapse_slashes": { "type": "boolean" },
                "remove_dot_segments": { "type": "boolean" }
              }
            }
          }
        }
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "match"],
        "properties": {
          "name": { "type": "string" },
          "match": { "type": "object", "properties": { "path_prefixes": { "type": "array", "items": { "type": "string" } } } },
          "auth_gate": {
            "type": "object",
            "properties": {
              "type": { "enum": ["static_token", "basic_auth", "jwt", "signed_url"] },
              "header": { "type": "string" },
              "token_env": { "type": "string" },
              "credentials_env": { "type": "string" },
              "algorithm": { "enum": ["HS256", "RS256", "ES256", "HMAC-SHA256"] },
              "allowed_algorithms": {
                "description": "Optional whitelist of JWT header `alg` values accepted at verify time. If omitted, only the gate's configured `algorithm` is accepted. `none` is always rejected.",
                "type": "array",
                "items": { "enum": ["HS256", "RS256", "ES256"] }
              },
              "clock_skew_sec": {
                "description": "Tolerance (in seconds) applied to JWT exp/nbf checks. Default 30.",
                "type": "integer",
                "minimum": 0,
                "maximum": 600
              },
              "jwks_url": { "type": "string" },
              "issuer": { "type": "string" },
              "audience": { "type": "string" },
              "secret_env": { "type": "string" },
              "cache_ttl_sec": {
                "description": "TTL (seconds) for cached gate material (for example, JWKS responses). Bounded to 24h to force rotation windows.",
                "type": "integer",
                "minimum": 0,
                "maximum": 86400
              },
              "expires_param": { "type": "string" },
              "signature_param": { "type": "string" }
            }
          },
          "response": { "type": "object", "properties": { "cache_control": { "type": "string" } } },
          "request": { "type": "object", "properties": { "allow_methods": { "type": "array", "items": { "type": "string" } } } }
        }
      }
    },
    "response_headers": {
      "type": "object",
      "properties": {
        "hsts": { "type": "string" },
        "x_content_type_options": { "type": "string" },
        "referrer_policy": { "type": "string" },
        "permissions_policy": { "type": "string" },
        "csp_public": { "type": "string" },
        "csp_admin": { "type": "string" },
        "cors": {
          "type": "object",
          "properties": {
            "allow_origins": { "type": "array", "items": { "type": "string" } },
            "allow_methods": { "type": "array", "items": { "type": "string" } },
            "allow_headers": { "type": "array", "items": { "type": "string" } },
            "expose_headers": { "type": "array", "items": { "type": "string" } },
            "allow_credentials": { "type": "boolean" },
            "max_age": {
              "description": "CORS preflight cache duration in seconds. Most browsers cap this at 86400 (Chrome) or 7200 (Firefox).",
              "type": "integer",
              "minimum": 0,
              "maximum": 86400
            }
          }
        },
        "cookie_attributes": {
          "type": "object",
          "properties": {
            "secure": { "type": "boolean" },
            "http_only": { "type": "boolean" },
            "same_site": { "enum": ["Strict", "Lax", "None"] }
          }
        }
      }
    },
    "firewall": {
      "type": "object",
      "properties": {
        "waf": {
          "type": "object",
          "properties": {
            "rate_limit": {
              "description": "Per-IP request ceiling over the 5-minute WAF rate-based window. AWS WAFv2 accepts 100..2,000,000,000.",
              "type": "integer",
              "minimum": 100,
              "maximum": 2000000000
            },
            "scope": { "enum": ["REGIONAL", "CLOUDFRONT"] },
            "managed_rules": { "type": "array", "items": { "type": "string" } },
            "ja3_fingerprints": { "type": "array", "items": { "type": "string" } },
            "ja4_fingerprints": { "type": "array", "items": { "type": "string" } },
            "fingerprint_action": { "enum": ["block", "count"] }
          }
        },
        "geo": {
          "type": "object",
          "properties": {
            "block_countries": { "type": "array", "items": { "type": "string" } },
            "allow_countries": { "type": "array", "items": { "type": "string" } }
          }
        },
        "ip": {
          "type": "object",
          "properties": {
            "allowlist": { "type": "array", "items": { "type": "string" } },
            "blocklist": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "transport": {
      "type": "object",
      "properties": {
        "tls": {
          "type": "object",
          "properties": {
            "minimum_version": { "enum": ["TLSv1.2", "TLSv1.3"] },
            "security_policy": { "type": "string" }
          }
        },
        "http": {
          "type": "object",
          "properties": {
            "versions": { "type": "array", "items": { "enum": ["http1.1", "http2", "http3"] } }
          }
        }
      }
    },
    "origin": {
      "type": "object",
      "properties": {
        "auth": {
          "type": "object",
          "properties": {
            "type": { "enum": ["custom_header"] },
            "header": { "type": "string" },
            "secret_env": { "type": "string" }
          }
        },
        "timeout": {
          "type": "object",
          "properties": {
            "connect": {
              "description": "Origin connect timeout in seconds. CloudFront caps this at 10s.",
              "type": "integer",
              "minimum": 1,
              "maximum": 10
            },
            "read": {
              "description": "Origin read/response timeout in seconds. CloudFront caps this at 60s.",
              "type": "integer",
              "minimum": 1,
              "maximum": 60
            }
          }
        }
      }
    }
  }
}
